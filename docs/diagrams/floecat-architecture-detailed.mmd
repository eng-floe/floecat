flowchart LR
  subgraph Clients["Clients"]
    QE["Query Engine"]
    Admin["Admin UI / CLI"]
  end

  subgraph Boundary["Trust Boundary"]
    ING["Ingress Auth / Context\nOIDC or dev mode -> PrincipalContext"]
    GW["Iceberg REST Gateway\nREST -> gRPC"]

    subgraph Query["Query / Planning Services"]
      QAPI["QueryService\nBeginQuery / RenewQuery / EndQuery / GetQuery"]
      QSCHEMA["QuerySchemaService\nDescribeInputs"]
      PSTATS["PlannerStatsService\nGetTargetStats / GetTableConstraints"]
      QSCAN["QueryScanService\nFetchScanBundle"]
      QCACHE["QueryContextStore\nCaffeine"]
      PCACHE["Per-query stats / pin cache"]
    end

    subgraph Catalog["Catalog / Metadata Services"]
      DIR["DirectoryService"]
      CAT["Catalog / Namespace /\nTable / View / Snapshot"]
      TX["TransactionsService"]
      TSTAT["TableStatisticsService"]
      CONSTR["TableConstraintsService"]
      CONN["Connectors API"]
    end

    subgraph Workers["Workers"]
      RCTL["ReconcileControl\nStartCapture"]
      RSCH["ReconcilePlannerScheduler"]
      REX["Reconcile Executors"]
      GC["GC\ntransactions / reconcile-jobs /\nCAS blobs / pointers"]
      ESTAT["Native Stats Engines\niceberg_native, delta_native"]
    end
  end

  KV["Pointer Store / KV"]
  OBJ["Blob Store / Object Storage"]
  UP["Upstream Metastores & Data Lakes"]

