# Built-in function definitions — replace the examples below with your engine's actual functions.
#
# Fields:
#   name            — function identifier + schema path
#   argument_types  — ordered list of parameter type refs (repeat block for each argument)
#   return_type     — return type ref
#   is_aggregate    — true for aggregate state-transition / finalizer functions
#   is_window       — true for window functions
#
# engine_specific:
#   payload_type  — identifies the payload schema (required by the catalog validator).
#                   Use a value like "example.properties" when there is no binary payload.
#   min_version   — earliest engine version that supports this function (inclusive).
#                   Functions with min_version are automatically excluded when Floecat
#                   serves a catalog for an older engine version.
#   max_version   — latest engine version that supports this function (inclusive)
#   properties    — free-form key/value metadata (description, volatility, internal IDs, etc.)

# Example scalar function with a single argument.
# Replace name, argument_types, return_type, and properties with your actual function.

functions {
  name {
    path: "example"
    name: "my_function"
  }
  argument_types {
    path: "example"
    name: "my_type"
  }
  return_type {
    path: "example"
    name: "my_type"
  }
  engine_specific {
    payload_type: "example.properties"
    properties {
      key: "description"
      value: "replace with your function description"
    }
    properties {
      key: "volatility"
      value: "immutable"
    }
  }
}

# Example function available only from a minimum engine version.
# Demonstrates version-gating: this entry is excluded for engine versions >= 2.0.
# Replace name, types, min_version, and properties with your actual versioned function.
functions {
  name {
    path: "example"
    name: "my_versioned_function"
  }
  argument_types {
    path: "example"
    name: "my_type"
  }
  return_type {
    path: "example"
    name: "my_type"
  }
  engine_specific {
    min_version: "2.0"
    payload_type: "example.properties"
    properties {
      key: "description"
      value: "replace: only available since engine version 2.0"
    }
  }
}
