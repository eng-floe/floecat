# Built-in infix operator definitions — replace the example below with your engine's actual operators.
#
# Fields:
#   name           — operator symbol (e.g., "+", "-", "*", "/", "||", "&&")
#   left_type      — left operand type ref
#   right_type     — right operand type ref
#   return_type    — result type ref
#   is_commutative — true when operands can be swapped without changing the result
#                    (e.g., a + b = b + a)
#   is_associative — true when grouping of repeated applications does not matter
#                    (e.g., (a + b) + c = a + (b + c))

# Example commutative and associative operator (e.g., addition).
# Replace name, operand types, and flags with your actual operator.

operators {
  name {
    name: "+"
  }
  left_type {
    path: "example"
    name: "my_type"
  }
  right_type {
    path: "example"
    name: "my_type"
  }
  return_type {
    path: "example"
    name: "my_type"
  }
  is_commutative: true
  is_associative: true
}
