# Built-in aggregate function definitions — replace the example below with your engine's actual aggregates.
#
# Fields:
#   name           — aggregate identifier + schema path
#   argument_types — input column type(s) (repeat block for each argument)
#   state_type     — type of the running accumulator state
#   return_type    — type returned after finalization
#
# Use engine_specific.properties to reference the corresponding state-transition and
# finalizer scalar functions (which you define in 20_functions.pbtxt).

# Example aggregate function.
# Replace name, types, and properties with your actual aggregate.
aggregates {
  name { name: "my_aggregate" path: "example" }
  argument_types { name: "my_type" path: "example" }
  state_type  { name: "my_type" path: "example" }
  return_type { name: "my_type" path: "example" }
  engine_specific {
    payload_type: "example.properties"
    properties { key: "description"      value: "replace with your aggregate description" }
    properties { key: "state_function"   value: "my_state_function" }
    properties { key: "final_function"   value: "my_final_function" }
  }
}
